<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:APM_Crate.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:APM_Crate.Views"
        mc:Ignorable="d" d:DesignWidth="555" d:DesignHeight="140"
        x:Class="APM_Crate.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"

        FontFamily="{DynamicResource MainFont}"
        Background="{DynamicResource ColorBackgroundBorder}"
        Title="{Binding Version, StringFormat='АРМ проверки и настройки контроллеров ТИК-Крейт v:{0}'}"
        
        SizeToContent="WidthAndHeight"
        CanMaximize="False"
        CanResize="False"
        Padding="10">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Window.KeyBindings>
	  <KeyBinding Command="{Binding OpenIpRestCommand}" Gesture="Ctrl+R" />
	  <KeyBinding Command="{Binding OpenParametersCommand}" Gesture="Ctrl+P" />
	</Window.KeyBindings>

    <Panel>

		<Border 
    Background="{DynamicResource ColorBackgroundBorder}"
          ZIndex="1"
          Opacity="0.65" 
          Padding="0"
          IsVisible="{Binding !SettingViewModel.IsEnabledButtons}">
         <Border
         Background="{DynamicResource ColorBackgroundBorder}">
             <StackPanel 
             VerticalAlignment="Center"
             Spacing="10" Opacity="3.08">
				 
             <ProgressBar Value="{Binding SettingViewModel.ProgressValue}"
        Minimum="0" Maximum="100"
                     Height="20"/>
                 <TextBlock Text="{Binding SettingViewModel.ProgressText}"
    TextWrapping="Wrap"
               HorizontalAlignment="Center" 
               VerticalAlignment="Center"/> 

             <ProgressBar Value="{Binding SettingViewModel.ProgressValueChannel}"
        Minimum="0" Maximum="100"
                     Height="20"/>
                 <TextBlock Text="{Binding SettingViewModel.ProgressTextChannel}"
    TextWrapping="Wrap"
               HorizontalAlignment="Center" 
               VerticalAlignment="Center"/> 
             </StackPanel>
						
         </Border>

            </Border>

      <Grid   ColumnDefinitions="Auto,*" ColumnSpacing="10"  >
			  <local:DevicesUserControl
              DataContext="{Binding DevicesViewModel}"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Grid.Column="0"/>
					
                
          <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="10"  >
			  <local:SettingUserControl
              HorizontalAlignment="Left" 
              DataContext="{Binding SettingViewModel}"
              Grid.Row="0"/>
          
			   <Panel Grid.Row="1" Width="263" Height="254" >
              <Button 
              ZIndex="1"
              Content="X"
              Command="{Binding ClearLogCommand}" VerticalAlignment="Bottom" HorizontalAlignment="Right"
              MinHeight="20" Height="25" Padding="0" Width="25" MinWidth="20"/>
        


			<TextBox
            Name="LogTextBox"
            TextChanged="WriteTextCommand"
            
            Focusable="False"
            DataContext="{Binding LogerViewModel}"
            Text="{Binding LogText}"
         FontSize="12"
         IsReadOnly="True"
         AcceptsReturn="True"
         AcceptsTab="True"
         TextWrapping="Wrap"
         BorderBrush="#A0A0A0"
         HorizontalAlignment="Stretch"
         VerticalContentAlignment="Top"
        ScrollViewer.VerticalScrollBarVisibility="Hidden"
        ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
         </Panel>
          </Grid>

	</Grid>

    </Panel>
</Window>
