<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Design.PreviewWith>
    <Border Padding="20">
      <CheckBox/>
    </Border>
  </Design.PreviewWith>

  <Style Selector="CheckBox">
	  <Setter Property="CornerRadius" Value="0"/>
  </Style>
</Styles>
