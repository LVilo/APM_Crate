<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="APM_Crate.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
  <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://APM_Crate/ResourceDictionarys/ColorsResourceDictionary.axaml"/>
                <ResourceInclude Source="avares://APM_Crate/ResourceDictionarys/FontResourceDictionary.axaml"/>
                <ResourceInclude Source="avares://APM_Crate/ResourceDictionarys/SizeResourceDictionary.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://APM_Crate/Styles/ComboBoxStyle.axaml"/>
        <StyleInclude Source="avares://APM_Crate/Styles/GridStyle.axaml"/>
        <StyleInclude Source="avares://APM_Crate/Styles/ButtonsStyle.axaml"/>
        <StyleInclude Source="avares://APM_Crate/Styles/TextBoxsStyle.axaml"/>
        <StyleInclude Source="avares://APM_Crate/Styles/BordersStyle.axaml"/>
        <StyleInclude Source="avares://APM_Crate/Styles/ScrollViewersStyle.axaml"/>
        <StyleInclude Source="avares://APM_Crate/Styles/DockPanelStyle.axaml"/>
        <StyleInclude Source="avares://APM_Crate/Styles/TextBlocksStyle.axaml"/>
        <StyleInclude Source="avares://APM_Crate/Styles/CheckBoxStyle.axaml"/>
    </Application.Styles>
</Application>