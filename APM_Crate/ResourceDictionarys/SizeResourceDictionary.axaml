<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
 
  <Design.PreviewWith>
    <Border Padding="20">
        <StackPanel Spacing="5">
        <ComboBox   MinHeight="{DynamicResource MainMinHeight}"/>
        <TextBox Text="Пример текста"   MinHeight="{DynamicResource MainMinHeight}"/>
			
        </StackPanel>
    </Border>
  </Design.PreviewWith>

      <!-- Add Resources Here -->
 <x:Double x:Key="MainMinHeight">25</x:Double>
</ResourceDictionary>
